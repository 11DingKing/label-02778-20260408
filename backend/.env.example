# 人才网后端环境变量配置示例
# 复制此文件为 .env 并修改为实际值

# 数据库连接（本地开发使用 127.0.0.1，Docker 部署使用 db）
DATABASE_URL=mysql://talent:talent123@127.0.0.1:3306/talent_db

# JWT 密钥（生产环境必须替换为 64 字符以上的随机密钥）
# ⚠️ 以下为开发示例值，生产环境必须替换！
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_SECRET_FOR_PRODUCTION_DEPLOYMENT_NOW

# 服务监听地址
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 可选配置
# UPLOAD_DIR=uploads                    # 文件上传目录，默认 uploads
# DAILY_CONTACT_LIMIT=3                 # 企业每日联系求职者上限，默认 3
# CORS_ORIGIN=https://example.com       # CORS 允许的域名，多个用逗号分隔
# 本地开发默认值：
CORS_ORIGIN=http://localhost:8081,http://localhost:8082
# RUST_LOG=info                         # 日志级别
